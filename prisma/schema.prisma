generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Application {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String
  email       String
  phone       String
  position    String
  coverLetter String
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
}
